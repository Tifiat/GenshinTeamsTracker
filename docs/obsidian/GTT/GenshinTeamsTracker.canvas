    },
    {
      "id": "work_import",
      "type": "text",
      "text": "[РАБОТАЕТ]\nИмпорт HoYoLAB\n\nhoyolab_export/\nЗабирает account JSON, детали персонажей, картинку export/share и готовит локальные файлы.",
      "x": -470,
      "y": -760,
      "width": 300,
      "height": 160,
      "color": "3"
    },
    {
      "id": "work_assets",
      "type": "text",
      "text": "[РАБОТАЕТ]\nКропы и локальные assets\n\ndata/hoyolab/crop_manifest.json\nassets/hoyolab/\nКартинки персонажей/оружия для UI.",
      "x": -130,
      "y": -760,
      "width": 300,
      "height": 160,
      "color": "3"
    },
    {
      "id": "work_artifact_browser",
      "type": "text",
      "text": "[????????]\nArtifact Browser\n\nui/artifact_browser/\n???????, ??????????, custom sets, build presets, set icons/tooltip.\n\n?????? ??????? ? AppShell ??? workspace \"Artifacts\". Equip/apply ???? ?????? scaffold, ??? ?????? ??????????.",
      "x": 210,
      "y": -760,
      "width": 300,
      "height": 170,
      "color": "5"
    },
    {
      "id": "work_artifact_db",
