    },
    {
      "id": "sb_session_equipment",
      "type": "text",
      "text": "[РАБОТАЕТ]\nAppShell team state vs equipment\n\nКоманды/слоты остаются UI state по режимам.\n\nCurrent weapon хранится persistent per character через account_equipment, не session memory.",
      "x": 250,
      "y": 980,
      "width": 330,
      "height": 170,
      "color": "4"
    },
    {
      "id": "sb_future_equipped_state",
      "type": "text",
      "text": "[???????]\nPersistent equipped state\n\nhoyolab_export/account_equipment.py\ndocs/handoff/ACCOUNT_EQUIPMENT_STATE_DESIGN.md\ndocs/handoff/ARTIFACT_BROWSER_EQUIPMENT_UX.md\n\nCanonical current weapon/artifact slots: schema + helpers ??? ????. AppShell weapon/artifact restore ????????.\n\nArtifact Browser C1 ?????????? target/current-equipment scaffold; writes ????? ?????.",
      "x": -560,
      "y": 410,
      "width": 300,
      "height": 195,
      "color": "4"
    }
