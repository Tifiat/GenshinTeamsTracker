diff --git a/pkg/gtt/info.go b/pkg/gtt/info.go
new file mode 100644
index 0000000..c647173
--- /dev/null
+++ b/pkg/gtt/info.go
@@ -0,0 +1,32 @@
+package gtt
+
+import (
+	"encoding/json"
+	"io"
+)
+
+const PatchVersion = "gtt-marker-v1"
+
+type EngineInfo struct {
+	GTTEngine       bool     `json:"gtt_engine"`
+	GTTPatchVersion string   `json:"gtt_patch_version"`
+	Capabilities    []string `json:"capabilities"`
+	SequentialWaves bool     `json:"sequential_waves"`
+	UpstreamVersion string   `json:"upstream_version,omitempty"`
+}
+
+func Info(upstreamVersion string) EngineInfo {
+	return EngineInfo{
+		GTTEngine:       true,
+		GTTPatchVersion: PatchVersion,
+		Capabilities:    []string{"gtt_engine_marker"},
+		SequentialWaves: false,
+		UpstreamVersion: upstreamVersion,
+	}
+}
+
+func WriteInfo(w io.Writer, upstreamVersion string) error {
+	encoder := json.NewEncoder(w)
+	encoder.SetEscapeHTML(false)
+	return encoder.Encode(Info(upstreamVersion))
+}
