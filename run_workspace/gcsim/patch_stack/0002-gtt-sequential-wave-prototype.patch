diff --git a/pkg/gtt/waves.go b/pkg/gtt/waves.go
new file mode 100644
index 0000000..b3d5426
--- /dev/null
+++ b/pkg/gtt/waves.go
@@ -0,0 +1,95 @@
+package gtt
+
+import (
+	"fmt"
+	"regexp"
+	"strconv"
+
+	"github.com/genshinsim/gcsim/pkg/core"
+	"github.com/genshinsim/gcsim/pkg/core/event"
+	"github.com/genshinsim/gcsim/pkg/core/glog"
+	"github.com/genshinsim/gcsim/pkg/core/info"
+	"github.com/genshinsim/gcsim/pkg/enemy"
+)
+
+const (
+	WaveSchedulerPrototypeCapability = "gtt_wave_scheduler_prototype"
+	WavePrototypeDirective           = "gtt_wave_prototype"
+)
+
+var (
+	anyWavePrototypeDirectivePattern = regexp.MustCompile(`(?m)^\s*(?:#|//)\s*gtt_wave_prototype\b.*$`)
+	wavePrototypeDirectivePattern    = regexp.MustCompile(`^\s*(?:#|//)\s*gtt_wave_prototype\s+duplicate_first_target\s*=\s*([0-9]+)\s*$`)
+)
+
+// ApplyConfigDirectives reads GTT-only comment directives from the raw config.
+// Vanilla GCSIM ignores these comments, so regular configs are unchanged unless
+// the prototype directive is explicitly present.
+func ApplyConfigDirectives(raw string, cfg *info.ActionList) error {
+	if cfg == nil {
+		return nil
+	}
+	matches := anyWavePrototypeDirectivePattern.FindAllString(raw, -1)
+	if len(matches) == 0 {
+		return nil
+	}
+	if len(matches) > 1 {
+		return fmt.Errorf("%s accepts exactly one directive, got %d", WavePrototypeDirective, len(matches))
+	}
+	parsed := wavePrototypeDirectivePattern.FindStringSubmatch(matches[0])
+	if parsed == nil {
+		return fmt.Errorf("invalid %s directive; expected '# %s duplicate_first_target=N'", WavePrototypeDirective, WavePrototypeDirective)
+	}
+	extraWaves, err := strconv.Atoi(parsed[1])
+	if err != nil || extraWaves <= 0 {
+		return fmt.Errorf("%s duplicate_first_target must be a positive integer", WavePrototypeDirective)
+	}
+	cfg.Settings.GTTSequentialWavePrototype = true
+	cfg.Settings.GTTSequentialWavePrototypeExtraWaves = extraWaves
+	return nil
+}
+
+type SequentialWavePrototypeScheduler struct {
+	core      *core.Core
+	prototype info.EnemyProfile
+	remaining int
+	spawned   int
+}
+
+func NewSequentialWavePrototypeScheduler(c *core.Core, cfg *info.ActionList) *SequentialWavePrototypeScheduler {
+	if c == nil || cfg == nil {
+		return nil
+	}
+	if !cfg.Settings.GTTSequentialWavePrototype || cfg.Settings.GTTSequentialWavePrototypeExtraWaves <= 0 {
+		return nil
+	}
+	if len(cfg.Targets) == 0 {
+		return nil
+	}
+	return &SequentialWavePrototypeScheduler{
+		core:      c,
+		prototype: cfg.Targets[0].Clone(),
+		remaining: cfg.Settings.GTTSequentialWavePrototypeExtraWaves,
+	}
+}
+
+func (s *SequentialWavePrototypeScheduler) SpawnNextWave() bool {
+	if s == nil || s.remaining <= 0 {
+		return false
+	}
+	profile := s.prototype.Clone()
+	nextEnemy := enemy.New(s.core, profile)
+	s.core.Combat.AddEnemy(nextEnemy)
+	s.core.Combat.DefaultTarget = nextEnemy.Key()
+	if player := s.core.Combat.Player(); player != nil {
+		player.SetDirection(nextEnemy.Pos())
+	}
+	s.core.Events.Emit(event.OnEnemyAdded, nextEnemy)
+	s.remaining--
+	s.spawned++
+	s.core.Log.NewEvent("gtt sequential wave prototype spawned target", glog.LogSimEvent, -1).
+		Write("spawned", s.spawned).
+		Write("remaining", s.remaining).
+		Write("target_key", nextEnemy.Key())
+	return true
+}
