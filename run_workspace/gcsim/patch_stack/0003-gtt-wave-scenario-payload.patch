+func cloneEnemyProfileWaves(waves [][]EnemyProfile) [][]EnemyProfile {
+	if len(waves) == 0 {
+		return nil
+	}
+	clone := make([][]EnemyProfile, len(waves))
+	for waveIndex := range waves {
+		clone[waveIndex] = make([]EnemyProfile, len(waves[waveIndex]))
+		for targetIndex := range waves[waveIndex] {
+			clone[waveIndex][targetIndex] = waves[waveIndex][targetIndex].Clone()
+		}
+	}
+	return clone
+}
