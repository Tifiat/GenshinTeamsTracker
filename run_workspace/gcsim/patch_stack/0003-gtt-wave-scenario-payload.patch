+
+// ApplyWaveScenarioFile applies an explicit structured GTT wave scenario. The
+// first scenario wave replaces the parsed config targets; remaining waves are
+// queued for the sequential wave scheduler. Empty path is a no-op so vanilla
+// configs remain unchanged unless this GTT flag is explicitly provided.
+func ApplyWaveScenarioFile(path string, cfg *info.ActionList) error {
+	if cfg == nil || strings.TrimSpace(path) == "" {
+		return nil
+	}
+	payload, err := loadWaveScenarioFile(path)
+	if err != nil {
+		return err
+	}
+	waves, err := payload.enemyWaves()
+	if err != nil {
+		return err
+	}
+	cfg.Targets = cloneWaveProfiles(waves[0])
+	cfg.GTTSequentialWaveScenario = cloneScenarioWaves(waves[1:])
+	cfg.Settings.DamageMode = true
+	cfg.Settings.GTTSequentialWavePrototype = true
+	cfg.Settings.GTTSequentialWavePrototypeExtraWaves = 0
+	return nil
+}
+
+func loadWaveScenarioFile(path string) (waveScenarioFile, error) {
+	data, err := os.ReadFile(path)
+	if err != nil {
+		return waveScenarioFile{}, fmt.Errorf("gtt wave scenario: could not read %q: %w", path, err)
+	}
+	decoder := json.NewDecoder(bytes.NewReader(data))
+	decoder.DisallowUnknownFields()
+	var payload waveScenarioFile
+	if err := decoder.Decode(&payload); err != nil {
+		return waveScenarioFile{}, fmt.Errorf("gtt wave scenario: invalid JSON in %q: %w", path, err)
+	}
+	return payload, nil
+}
+
+func (payload waveScenarioFile) enemyWaves() ([][]info.EnemyProfile, error) {
+	if payload.SchemaVersion != 1 {
+		return nil, fmt.Errorf("gtt wave scenario: schema_version must be 1")
+	}
+	if payload.SpawnPolicy != WaveScenarioSpawnPolicyGroupClear {
+		return nil, fmt.Errorf("gtt wave scenario: unsupported spawn_policy %q; expected %q", payload.SpawnPolicy, WaveScenarioSpawnPolicyGroupClear)
+	}
+	if len(payload.Waves) == 0 {
+		return nil, fmt.Errorf("gtt wave scenario: waves must contain at least one wave")
+	}
+	waves := make([][]info.EnemyProfile, len(payload.Waves))
+	for waveIndex, wave := range payload.Waves {
+		if len(wave.Targets) == 0 {
+			return nil, fmt.Errorf("gtt wave scenario: waves[%d].targets must contain at least one target", waveIndex)
+		}
+		waves[waveIndex] = make([]info.EnemyProfile, len(wave.Targets))
+		for targetIndex, target := range wave.Targets {
+			profile, err := target.enemyProfile(waveIndex, targetIndex)
+			if err != nil {
+				return nil, err
+			}
+			waves[waveIndex][targetIndex] = profile
+		}
+	}
+	return waves, nil
+}
+
+func (target waveScenarioTarget) enemyProfile(waveIndex int, targetIndex int) (info.EnemyProfile, error) {
+	prefix := fmt.Sprintf("gtt wave scenario: waves[%d].targets[%d]", waveIndex, targetIndex)
+	if target.Level == nil {
+		return info.EnemyProfile{}, fmt.Errorf("%s.level is required", prefix)
+	}
+	if *target.Level < 1 || *target.Level > 100 {
+		return info.EnemyProfile{}, fmt.Errorf("%s.level must be between 1 and 100", prefix)
+	}
+	if target.HP == nil {
+		return info.EnemyProfile{}, fmt.Errorf("%s.hp is required", prefix)
+	}
+	if *target.HP <= 0 {
+		return info.EnemyProfile{}, fmt.Errorf("%s.hp must be greater than 0", prefix)
+	}
+	if target.Radius == nil {
+		return info.EnemyProfile{}, fmt.Errorf("%s.radius is required", prefix)
+	}
+	if *target.Radius <= 0 {
+		return info.EnemyProfile{}, fmt.Errorf("%s.radius must be greater than 0", prefix)
+	}
+	if len(target.Pos) != 2 {
+		return info.EnemyProfile{}, fmt.Errorf("%s.pos must contain exactly two numbers", prefix)
+	}
+	if target.Resist == nil {
+		return info.EnemyProfile{}, fmt.Errorf("%s.resist is required", prefix)
+	}
+	return info.EnemyProfile{
+		Level:       *target.Level,
+		HP:          *target.HP,
+		Resist:      flatResistMap(*target.Resist),
+		Pos:         info.Coord{X: target.Pos[0], Y: target.Pos[1], R: *target.Radius},
+		MonsterName: fmt.Sprintf("gtt_wave_%d_target_%d", waveIndex+1, targetIndex+1),
+		Modified:    true,
+	}, nil
+}
+
+func flatResistMap(value float64) attributes.ElementMap {
+	resist := make(attributes.ElementMap)
+	for _, attr := range []attributes.Element{attributes.Electro, attributes.Cryo, attributes.Hydro, attributes.Physical, attributes.Pyro, attributes.Geo, attributes.Dendro, attributes.Anemo} {
+		resist[attr] = value
+	}
+	return resist
+}
