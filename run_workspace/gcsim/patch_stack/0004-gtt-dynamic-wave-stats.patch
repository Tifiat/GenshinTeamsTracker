diff --git a/pkg/stats/damage/damage_test.go b/pkg/stats/damage/damage_test.go
new file mode 100644
index 0000000..a07f4c0
--- /dev/null
+++ b/pkg/stats/damage/damage_test.go
@@ -0,0 +1,26 @@
+package damage
+
+import "testing"
+
+func TestEnsureTargetCountGrowsExistingBuckets(t *testing.T) {
+	b := buffer{
+		cumuTarget: [][]float64{
+			{11},
+			{22, 33},
+		},
+	}
+
+	b.ensureTargetCount(4)
+
+	for index, bucket := range b.cumuTarget {
+		if len(bucket) != 4 {
+			t.Fatalf("bucket %d length = %d, want 4", index, len(bucket))
+		}
+	}
+	if b.cumuTarget[0][0] != 11 {
+		t.Fatalf("first bucket existing value = %v, want 11", b.cumuTarget[0][0])
+	}
+	if b.cumuTarget[1][1] != 33 {
+		t.Fatalf("second bucket existing value = %v, want 33", b.cumuTarget[1][1])
+	}
+}

